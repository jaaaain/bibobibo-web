{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vite/client", "unplugin-auto-import", "unplugin-vue-components"]
  },
  "include": [
    "src/**/*.ts", "src/**/*.tsx", "src/**/*.vue",
    "src/auto-imports.d.ts",
    "src/components.d.ts"
  ]
}
